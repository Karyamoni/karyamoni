{
  "name": "karyamoni",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "dev:ui": "mprocs",
    "dev:all": "concurrently -n \"main,plugin,tunnel,tunnel:plugin\" -c \"blue,green,yellow,magenta\" \"next dev\" \"pnpm --filter karyamoni-ikas-plugin dev\" \"cloudflared tunnel --config ~/.cloudflared/config.yml run\" \"cloudflared tunnel --config ~/.cloudflared/config-plugin.yml run\"",
    "build": "next build",
    "start": "next start",
    "prisma:generate": "prisma generate",
    "studio": "prisma studio --port 5555",
    "studio:plugin": "pnpm --filter karyamoni-ikas-plugin exec prisma studio --port 5556",
    "studio:all": "concurrently -n \"main-db,plugin-db\" -c \"blue,green\" \"prisma studio --port 5555\" \"pnpm --filter karyamoni-ikas-plugin exec prisma studio --port 5556\"",
    "tunnel": "cloudflared tunnel --config ~/.cloudflared/config.yml run",
    "tunnel:plugin": "cloudflared tunnel --config ~/.cloudflared/config-plugin.yml run"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@react-three/fiber": "9.6.1",
    "@types/qrcode": "^1.5.6",
    "clsx": "2.1.1",
    "framer-motion": "11.18.2",
    "gsap": "^3.15.0",
    "lenis": "1.3.23",
    "lucide-react": "0.468.0",
    "next": "16.2.9",
    "next-intl": "4.13.0",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "three": "0.184.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/node": "22.10.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "autoprefixer": "10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "8.5.10",
    "prisma": "6.1.0",
    "tailwindcss": "3.4.17",
    "turbo": "^2.10.0",
    "typescript": "5.7.2"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@swc/core",
      "sharp",
      "@parcel/watcher",
      "unrs-resolver"
    ]
  }
}
