generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String?             @unique
  phone              String?             @unique
  name               String?
  image              String?
  locale             String              @default("tr")
  suspiciousAt       DateTime?
  mfaEnabled         Boolean             @default(false)
  mfaSecret          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           AuthAccount[]
  merchantProfile    MerchantProfile?
  playgroundSessions PlaygroundSession[]
  sessions           Session[]
  mfaPendingTokens   MfaPendingToken[]
  ikasLinkTokens     IkasLinkToken[]
}

model MfaPendingToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  ip        String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  issuedIp   String
  lastSeenIp String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model MerchantProfile {
  id          String           @id @default(cuid())
  userId      String           @unique
  companyName String?
  storeUrl    String?
  platform    String           @default("ikas")
  status      String           @default("pilot")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stores      DashboardStore[]
}

model PlaygroundSession {
  id        String   @id @default(cuid())
  userId    String?
  locale    String   @default("tr")
  product   Json
  bodyInput Json
  fitResult Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model DashboardStore {
  id                String             @id @default(cuid())
  merchantProfileId String
  name              String
  platform          String             @default("ikas")
  installStatus     String             @default("not_connected")
  permissionStatus  String             @default("pending")
  activationStatus  String             @default("draft")
  accessToken       String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  merchantProfile   MerchantProfile    @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  metrics           DashboardMetric[]
}

model DashboardMetric {
  id             String         @id @default(cuid())
  dashboardStoreId String
  name           String
  value          Float
  unit           String
  period         String
  createdAt      DateTime       @default(now())
  dashboardStore DashboardStore @relation(fields: [dashboardStoreId], references: [id], onDelete: Cascade)
}

model IkasLinkToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
